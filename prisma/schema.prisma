generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id             String         @id @default(uuid())
  email          String         @unique
  displayName    String?
  isAdmin        Boolean        @default(false)
  createdAt       DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  availabilities     Availability[]
  recommendedBooks   Book[]           @relation("BookRecommender")

  @@map("bookclub_profiles")
}

model SchedulingPoll {
  id        String         @id @default(uuid())
  status    String         @default("IDLE")
  finalDate DateTime?
  location  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  dates     ProposedDate[]

  @@map("bookclub_scheduling_polls")
}

model ProposedDate {
  id        String         @id @default(uuid())
  pollId    String
  date      DateTime
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  responses Availability[]
  poll      SchedulingPoll @relation(fields: [pollId], references: [id])

  @@map("bookclub_proposed_dates")
}

model Availability {
  id        String       @id @default(uuid())
  userId    String
  dateId    String
  status    String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  date      ProposedDate @relation(fields: [dateId], references: [id])
  user      Profile      @relation(fields: [userId], references: [id])

  @@unique([userId, dateId])
  @@map("bookclub_availabilities")
}

enum BookStatus {
  FUTURE_SUGGESTION
  NEXT
  COMPLETED
}

model Book {
  id            String     @id @default(uuid())
  title         String
  author        String?
  coverUrl      String?
  status        BookStatus @default(FUTURE_SUGGESTION)
  recommenderId String?
  completedAt   DateTime?
  selectedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  recommender   Profile?   @relation("BookRecommender", fields: [recommenderId], references: [id])

  @@index([status, createdAt])
  @@map("bookclub_books")
}

model BookPoll {
  code      String   @id
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookclub_book_polls")
}
